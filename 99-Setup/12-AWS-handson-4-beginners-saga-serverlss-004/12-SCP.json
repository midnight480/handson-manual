{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyUnallowedServicesSCP",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "sts:*",
        "apigateway:*",
        "lambda:*",
        "dynamodb:*",
        "bedrock:*",
        "wafv2:*",
        "logs:*",
        "ec2:*",
        "elasticloadbalancing:*",
        "cloudfront:*",
        "ssm:*",
        "secretsmanager:*",
        "sns:*",
        "events:*",
        "cloudformation:*",
        "s3:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyUnapprovedRegions",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "sts:*",
        "wafv2:*",
        "cloudfront:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": [
            "us-east-1",
            "us-west-2",
            "ap-northeast-1",
            "ap-northeast-3"
          ]
        }
      }
    }
  ]
}

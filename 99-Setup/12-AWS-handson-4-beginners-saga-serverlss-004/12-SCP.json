{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyUnallowedServicesSCP",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "sts:*",
        "apigateway:*",
        "lambda:*",
        "dynamodb:*",
        "bedrock:*",
        "wafv2:*",
        "logs:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyUnapprovedRegions",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "sts:*",
        "wafv2:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": [
            "us-east-1",
            "us-west-2",
            "ap-northeast-1",
            "ap-northeast-3"
          ]
        }
      }
    }
  ]
}

{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyUnapprovedRegionsRCP",
      "Effect": "Deny",
      "Principal": "*",
      "Action": [
        "s3:*",
        "dynamodb:*",
        "logs:*",
        "sqs:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": [
            "us-east-1",
            "us-west-2",
            "ap-northeast-1",
            "ap-northeast-3"
          ]
        }
      }
    }
  ]
}
